# --- AWS / SST ----------------------------------------------------------------
# Profile name from `aws configure --profile speediance`.
AWS_PROFILE=speediance
AWS_REGION=us-west-2

# Populated after `pnpm sst deploy --stage dev` creates the user pool.
COGNITO_USER_POOL_ID=
COGNITO_USER_POOL_CLIENT_ID=

# --- Anthropic ----------------------------------------------------------------
# Used by packages/ai-coach and any local script that talks to Claude.
ANTHROPIC_API_KEY=

# --- Local dev overrides ------------------------------------------------------
# Set to "EU" to point the Speediance client at euapi.speediance.com instead
# of api2.speediance.com when running scripts locally.
SPEEDIANCE_REGION=Global
