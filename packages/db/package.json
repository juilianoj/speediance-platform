{
  "name": "@speediance/db",
  "version": "0.1.0",
  "private": true,
  "description": "DynamoDB access layer for speediance-platform. Single-table model, ElectroDB entities, and a user-scoped wrapper that enforces the USER#{id} partition rule.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.717.0",
    "@aws-sdk/lib-dynamodb": "^3.717.0",
    "electrodb": "^3.4.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@speediance/eslint-config": "workspace:*",
    "@types/node": "^22.10.5",
    "eslint": "^9.18.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
