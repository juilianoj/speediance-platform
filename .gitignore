# Dependencies
node_modules/
.pnpm-store/

# Local-only debug scripts — kept out of the deploy bundle and out of git
*.local.ts

# Build outputs
dist/
build/
.next/
out/
.turbo/
*.tsbuildinfo

# SST
.sst/
.open-next/

# Env / secrets — NEVER commit
# Block ANY .env* file (.env, .env.local, .env.backup, .env.prod, …) and then
# explicitly re-allow the documented example file.
.env*
!.env.example
*.pem
*.key
*.p12
*.pfx
aws-exports.js
config.json
# Speediance API cache the upstream Python client wrote to disk — we don't
# create these, but ignore them so a copy-pasted file from hbui3 doesn't leak.
library_cache_*.json

# Caches
.cache/
.eslintcache
.prettiercache
coverage/
.nyc_output/

# Editor
.vscode/*
!.vscode/extensions.json
!.vscode/settings.recommended.json
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*
*.log

# Playwright / test artifacts
test-results/
playwright-report/
playwright/.cache/
