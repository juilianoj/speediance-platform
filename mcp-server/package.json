{
  "name": "@speediance/mcp-server",
  "version": "0.1.0",
  "description": "Local MCP (Model Context Protocol) server exposing a slice of the Speediance AI Coach tools over stdio. Drop into Claude Desktop's MCP config to chat with your own training data.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "speediance-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/index.js",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@speediance/coach-safety": "workspace:*",
    "@speediance/db": "workspace:*",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@speediance/eslint-config": "workspace:*",
    "@types/node": "^22.10.5",
    "eslint": "^9.18.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
